{
    "name": "remonhasan/fastapi-crud-scaffold",
    "description": "Laravel package to generate API CRUD scaffolds with one command.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "FastApi\\CrudScaffold\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "FastApi\\CrudScaffold\\FastApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
